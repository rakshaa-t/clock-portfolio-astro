---
import Layout from '../../layouts/Layout.astro';
import { NOTES } from '../../data/notes.js';
import DockDemo from '../../components/demos/DockDemo.jsx';
import ResizeDemo from '../../components/demos/ResizeDemo.jsx';
import MorphDemo from '../../components/demos/MorphDemo.jsx';


const DEMO_MAP = { DockDemo, ResizeDemo, MorphDemo };

export function getStaticPaths() {
  return NOTES.filter(note => !note.mdx).map(note => ({
    params: { slug: note.slug },
    props: { note },
  }));
}

const { note } = Astro.props;

function renderBlock(block, sectionId) {
  if (block.type === 'text') {
    if (sectionId) return `<div id="section-${sectionId}">${block.html}</div>`;
    return block.html;
  }
  if (block.type === 'code') return `<div style="position:relative"><div class="note-code">${block.html}</div></div>`;
  if (block.type === 'image') {
    let html = `<div class="note-img">`;
    if (block.src) html += `<img src="${block.src}" alt="${block.caption || ''}" loading="lazy">`;
    html += `</div>`;
    if (block.caption) html += `<div class="note-img-caption">${block.caption}</div>`;
    return html;
  }
  if (block.type === 'callout') return `<div class="note-callout">${block.html}</div>`;
  if (block.type === 'demo') return `<div class="note-demo" data-demo-id="${block.id}"><div class="note-demo-label">Interactive</div><canvas width="460" height="${block.height || 140}"></canvas></div>`;
  return '';
}

// Extract TOC headings from rich note body (h2 section markers)
const tocHeadings = [];
if (note.rich && Array.isArray(note.body)) {
  note.body.forEach((block, i) => {
    if (block.type === 'text' && block.html) {
      const match = block.html.match(/<h2[^>]*class="note-h2"[^>]*>([^<]+)<\/h2>/);
      if (match) {
        const text = match[1];
        const id = text.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/-+$/, '');
        tocHeadings.push({ id, text, blockIndex: i });
      }
    }
  });
}

const bodyHtml = note.rich
  ? note.body.map(renderBlock).join('')
  : (typeof note.body === 'string' ? note.body : '');

const currentIdx = NOTES.findIndex(n => n.slug === note.slug);
const nextNote = NOTES[(currentIdx + 1) % NOTES.length];

const isTeardown = !!note.teardown;
const hasComponents = note.rich && note.body.some(b => b.type === 'component');
const isDev = import.meta.env.DEV;

const isoDate = note.sortDate
  ? String(note.sortDate).replace(/^(\d{4})(\d{2})(\d{2})$/, '$1-$2-$3')
  : undefined;
---

<Layout
  title={`${note.title} — Raksha Tated`}
  description={note.preview}
  ogImage={note.og}
  type="article"
  publishedTime={isoDate}
  tags={note.tags}
>

{isTeardown ? (
  <!-- ═══ TEARDOWN LAYOUT ═══ -->
  <div class="note-page teardown">
    <!-- Left: scrollable prose -->
    <div class="td-left">
      <a href="/#sec-notes" class="note-page-back t-tag">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        Back
      </a>
      <time class="td-date t-tag" datetime={isoDate}>{note.date}</time>
      <h1 class="td-title t-heading">{note.title}</h1>
      {note.teardown.intro && <p class="td-intro t-body">{note.teardown.intro}</p>}

      {note.teardown.chapters.map((chapter) => (
        <div>
          <h2 class="td-chapter t-heading-sm">{chapter.title}</h2>
          {chapter.sections.map((section) => (
            <div class="td-section" data-mockup={section.mockup || chapter.mockup || 'default'}>
              <div class="td-section-body">
                <div class="td-section-title t-heading-sm">{section.title}</div>
                <div class="td-section-text t-body-sm" set:html={section.body} />
              </div>
            </div>
          ))}
        </div>
      ))}
      <div class="note-page-footer">
        <button class="note-page-share t-tag" id="shareOnX">
          Share on <span class="sr-only">X</span><svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" style="margin-left:2px;" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </button>
      </div>
      {nextNote && nextNote.slug !== note.slug && (
        <div class="note-page-upnext">
          <div class="note-page-upnext-label t-tag">Up next</div>
          <a href={`/notes/${nextNote.slug}`} class="note-card">
            <div class="note-card-date t-tag">{nextNote.date}</div>
            <div class="note-card-title t-heading-sm">{nextNote.title}</div>
            <div class="note-card-preview t-body-sm">{nextNote.preview}</div>
          </a>
        </div>
      )}
    </div>

    <!-- Right: static mockup panel, full viewport height -->
    <div class="td-preview">
      <div class="td-preview-inner">
        {note.teardown.mockups.map((mockup) => (
          <div class={`td-mockup${mockup.id === note.teardown.mockups[0].id ? ' active' : ''}`} data-mockup-id={mockup.id}>
            {mockup.frames.map((frame) => (
              <div class="td-mockup-frame">
                <img src={frame.src} alt={frame.alt || ''} loading="lazy" />
              </div>
            ))}
          </div>
        ))}
      </div>
    </div>
  </div>

  <script>
    import '../../scripts/teardown-engine.js';
  </script>
  <script is:inline data-astro-rerun>
    if(window.__initTeardown) window.__initTeardown();
  </script>
) : (
  <!-- ═══ STANDARD NOTE LAYOUT ═══ -->
  <div class="note-page">

    <div class="note-page-inner">
      <a href="/#sec-notes" class="note-page-back t-tag">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        Back
      </a>
      <time class="note-page-date t-tag" datetime={isoDate}>{note.date}</time>
      <h1 class="note-page-title t-heading">{note.title}</h1>

      {/* ── Body: block-level rendering for React islands ── */}
      <article class="note-page-body t-body">
        {hasComponents ? (
          note.body.map((block, i) => {
            if (block.type === 'component') {
              return (
                <div class={`note-component${block.id === 'DockDemo' ? ' hide-mobile' : ''}`}>
                  {block.id === 'DockDemo' && <DockDemo client:load />}
                  {block.id === 'ResizeDemo' && <ResizeDemo client:load />}
                  {block.id === 'MorphDemo' && <MorphDemo client:load />}
                  {block.hint && <div class="note-component-hint">{block.hint}</div>}
                </div>
              );
            }
            const heading = tocHeadings.find(h => h.blockIndex === i);
            const sectionId = heading ? heading.id : null;
            return <Fragment set:html={renderBlock(block, sectionId)} />;
          })
        ) : note.rich ? (
          note.body.map((block, i) => {
            const heading = tocHeadings.find(h => h.blockIndex === i);
            const sectionId = heading ? heading.id : null;
            return <Fragment set:html={renderBlock(block, sectionId)} />;
          })
        ) : (
          <Fragment set:html={bodyHtml} />
        )}
      </article>

      <div class="note-page-footer">
        <button class="note-page-share t-tag" id="shareOnX">
          Share on <span class="sr-only">X</span><svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" style="margin-left:2px;" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </button>
      </div>
      {nextNote && nextNote.slug !== note.slug && (
        <div class="note-page-upnext">
          <div class="note-page-upnext-label t-tag">Up next</div>
          <a href={`/notes/${nextNote.slug}`} class="note-card">
            <div class="note-card-date t-tag">{nextNote.date}</div>
            <div class="note-card-title t-heading-sm">{nextNote.title}</div>
            <div class="note-card-preview t-body-sm">{nextNote.preview}</div>
          </a>
        </div>
      )}
    </div>
  </div>
)}

<script>
  const shareBtn = document.getElementById('shareOnX');
  if (shareBtn) {
    shareBtn.addEventListener('click', () => {
      const title = document.querySelector('.note-page-title, .td-title')?.textContent || '';
      window.open(`https://x.com/intent/tweet?text=${encodeURIComponent(`"${title}"\n\nhttps://raksha.design${window.location.pathname}`)}`, '_blank');
    });
  }
  // Note card click sound (Up Next card)
  document.querySelectorAll('.note-card').forEach(card => {
    card.addEventListener('click', () => {
      if (window.__clockAudio) window.__clockAudio.noteClick();
    });
  });
</script>

<!-- ═══ Skill Filters + Copy ═══ -->
<script>
  // Skill category filters
  const skillFilters = document.getElementById('skillFilters');
  if (skillFilters) {
    skillFilters.addEventListener('click', (e) => {
      const pill = e.target.closest('.mymind-pill');
      if (!pill) return;
      const filter = pill.dataset.filter;
      skillFilters.querySelectorAll('.mymind-pill').forEach(p =>
        p.classList.toggle('active', p.dataset.filter === filter)
      );
      document.querySelectorAll('[data-skill-cat]').forEach(el => {
        if (filter === 'all') el.classList.remove('skill-hidden');
        else el.classList.toggle('skill-hidden', el.dataset.skillCat !== filter);
      });
    });
  }
  // Copy install commands
  document.querySelectorAll('.note-code-copy[data-cmd]').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      navigator.clipboard.writeText(btn.dataset.cmd).then(() => {
        btn.textContent = 'Copied!';
        btn.classList.add('copied');
        setTimeout(() => { btn.textContent = 'Copy'; btn.classList.remove('copied'); }, 1500);
      });
    });
  });
</script>

<!-- ═══ TOC Scroll Tracking ═══ -->
<script>
  function initTOC() {
    const links = document.querySelectorAll('.note-toc-link');
    if (!links.length) return;

    const targets = [];
    links.forEach(link => {
      const id = link.dataset.tocTarget;
      const el = document.getElementById(id);
      if (el) targets.push({ el, link });
    });
    if (!targets.length) return;

    let activeLink = null;

    const observer = new IntersectionObserver((entries) => {
      let best = null;
      entries.forEach(e => {
        if (e.isIntersecting && (!best || e.boundingClientRect.top < best.boundingClientRect.top)) {
          best = e;
        }
      });
      if (best) {
        const match = targets.find(t => t.el === best.target);
        if (match && match.link !== activeLink) {
          if (activeLink) activeLink.classList.remove('active');
          match.link.classList.add('active');
          activeLink = match.link;
        }
      }
    }, {
      root: null,
      rootMargin: '-10% 0px -50% 0px',
      threshold: [0, 0.25, 0.5, 0.75, 1]
    });

    targets.forEach(t => observer.observe(t.el));

    // Activate first by default
    if (targets[0]) {
      targets[0].link.classList.add('active');
      activeLink = targets[0].link;
    }

    // Click to smooth-scroll
    links.forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const id = link.dataset.tocTarget;
        const el = document.getElementById(id);
        if (!el) return;
        const rect = el.getBoundingClientRect();
        const targetY = window.scrollY + rect.top - 80;
        const startY = window.scrollY;
        const diff = targetY - startY;
        const duration = Math.min(600, Math.max(300, Math.abs(diff) * 0.5));
        const startTime = performance.now();
        function easeOut(t) { return 1 - Math.pow(1 - t, 3); }
        function step(now) {
          const progress = Math.min((now - startTime) / duration, 1);
          window.scrollTo(0, startY + diff * easeOut(progress));
          if (progress < 1) requestAnimationFrame(step);
        }
        requestAnimationFrame(step);
      });
    });

    document.addEventListener('astro:before-swap', () => {
      observer.disconnect();
    }, { once: true });
  }

  initTOC();
  document.addEventListener('astro:page-load', initTOC);

  // Autoplay note videos only when reduced motion is not preferred
  document.querySelectorAll('.note-video').forEach(v=>{
    if(!window.matchMedia('(prefers-reduced-motion: reduce)').matches){
      v.play().catch(()=>{});
    }
  });
</script>


</Layout>
