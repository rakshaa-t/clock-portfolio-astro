---
import Layout from '../layouts/Layout.astro';
import { NOTES } from '../data/notes.js';
---

<Layout title="Raksha Tated | Product Designer" description="Product Designer. Five years designing products, one year engineering them. Tech, healthcare and consumer apps. Select client work available.">

<!-- ═══ MODAL ═══ -->
<div class="modal-overlay" id="modalOverlay">
  <div class="modal-backdrop" onclick="closeModal()" role="button" tabindex="-1" aria-label="Close modal"></div>
  <div class="modal-card" id="modalCard" role="dialog" aria-modal="true" aria-labelledby="modalTitle">
    <div class="sheet-handle"></div>
    <div class="modal-card-inner">
      <!-- Image area -->
      <div class="modal-carousel">
        <div class="carousel-scroll" id="carouselScroll"></div>
        <div class="carousel-counter" id="carouselCounter">1 / 3</div>
        <button class="modal-close" onclick="closeModal()" aria-label="Close modal">✕</button>
        <button class="carousel-btn prev" onclick="carouselPrev()" aria-label="Previous slide"><svg width="10" height="16" viewBox="0 0 10 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="8 2 2 8 8 14"/></svg></button>
        <button class="carousel-btn next" onclick="carouselNext()" aria-label="Next slide"><svg width="10" height="16" viewBox="0 0 10 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 2 8 8 2 14"/></svg></button>
      </div>
      <!-- Metadata area -->
      <div class="modal-body" id="modalBody">
        <div class="modal-meta">
          <h3 class="modal-title t-heading" id="modalTitle"></h3>
          <div class="modal-tags" id="modalTags"></div>
        </div>
        <div class="modal-desc-wrap" id="modalDescWrap">
          <p class="modal-desc t-body" id="modalDesc"></p>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ═══ PAGE CONTENT ═══ -->
<main class="page-content" id="mainContent">
  <div class="page-inner">

    <!-- ═══ ABOUT — Bio + CTAs ═══ -->
    <div class="browse-section" id="sec-about">
      <h1 class="t-display">Raksha Tated</h1>
      <p class="subtitle t-subtitle">Product Designer</p>

      <div class="about-bio">
        <p class="t-body">I work with <span class="about-drop-trigger" data-drop="agencies">agencies</span> and <span class="about-drop-trigger" data-drop="companies">product companies</span>, mostly on consumer iOS apps, healthcare platforms and AI software. I care a lot about the space between design and code.</p>
        <p class="t-body">If you'd like to work together, <a href="https://cal.com/raksha-tated-v2ee58/15min" class="about-bio-link cal-trigger" onclick="event.preventDefault()">book a call</a> or email <a href="mailto:hey@raksha.design" class="about-bio-link" id="aboutEmailLink">hey@raksha.design</a>. I'll get back within 12 hours. For anything else, <a href="https://x.com/rakshaa_t" class="about-bio-link" target="_blank" rel="noopener noreferrer">DM me on X</a>.</p>
      </div>

      <div class="about-ctas">
        <div class="about-cta-primary-wrap">
          <a href="https://cal.com/raksha-tated-v2ee58/15min?user=raksha-tated-v2ee58" class="about-cta-primary cal-trigger" onclick="event.preventDefault()">Reach out <svg class="cta-arrow" width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 12L12 4"/><path d="M5 4h7v7"/></svg></a>
        </div>
        <div class="about-cta-strip">
          <a href="https://x.com/rakshaa_t" class="about-cta" aria-label="Twitter" data-tip="X" target="_blank" rel="noopener noreferrer">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4l11.733 16h4.267l-11.733-16zM4 20l6.768-6.768M17.5 4l-6.768 6.768"/></svg>
          </a>
          <a href="https://github.com/rakshaa-t" class="about-cta" aria-label="GitHub" data-tip="GitHub" target="_blank" rel="noopener noreferrer">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
          </a>
          <a href="https://www.linkedin.com/in/rakshatated/" class="about-cta" aria-label="LinkedIn" data-tip="LinkedIn" target="_blank" rel="noopener noreferrer">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
        </div>
      </div>

      <div class="about-details">
        <div class="about-detail">
          <span class="about-detail-label t-tag">Timezones</span>
          <span class="about-detail-value t-body-sm">
            <span class="toggle" id="locationToggle" role="switch" aria-checked="false" aria-label="Toggle timezone display" tabindex="0"><span class="toggle-knob"></span></span>
            <span id="locationText">IST, UTC+0 and AEDT</span>
          </span>
        </div>
        <div class="about-detail">
          <span class="about-detail-label t-tag">Status</span>
          <span class="about-detail-value t-body-sm"><span class="led"></span>In the studio</span>
        </div>
        <div class="about-detail">
          <span class="about-detail-label t-tag">Stack</span>
          <span class="stack-cards">
            <span class="stack-card t-tag">Figma</span>
            <span class="stack-card t-tag">React</span>
            <span class="stack-card t-tag">SwiftUI</span>
            <span class="stack-card t-tag">Claude Code</span>
          </span>
        </div>
      </div>
    </div>

    <!-- ═══ WORK — Puzzle grid with category filters ═══ -->
    <div class="browse-section" id="sec-work">
      <h2 class="t-display">Work</h2>
      <p class="subtitle t-subtitle">Select client and personal work</p>

      <div class="puzzle-filters" id="puzzleFilters">
