<script is:inline data-astro-rerun>
  // Init all sections + scroll restoration.
  // Runs on every navigation via data-astro-rerun.
  // Module scripts also register astro:page-load listeners as a backup
  // for back/forward navigations where data-astro-rerun may not re-fire.
  (async function(){
    function ready(){
      return new Promise(function(r){
        if(document.readyState==='loading') document.addEventListener('DOMContentLoaded',r,{once:true});
        else r();
      });
    }
    await ready();
    // If modules haven't set their globals yet, wait briefly for them
    if(!window.__initPortfolioCore){
      await new Promise(function(r){setTimeout(r,0);});
    }
    if(window.__initPortfolioCore) window.__initPortfolioCore();
    if(window.__initBooks) window.__initBooks();
    if(window.__initMymind) window.__initMymind();
    if(window.__initPodcasts) window.__initPodcasts();
    if(window.__initAbout) window.__initAbout();
    if(window.__initBottomNav) window.__initBottomNav();
    if(window.__initScrollEffects) window.__initScrollEffects();
    if(window.__initAudio) window.__initAudio();
    // Restore scroll position after init scripts have built the DOM.
    // Astro's built-in restore fires too early (before JS-generated grids).
    // Hash navigation (e.g. back from notes via /#sec-notes) takes priority
    // over saved scroll position so the user lands on the right section.
    var hash=location.hash&&location.hash.substring(1);
    var hashEl=hash&&document.getElementById(hash);
    if(hashEl){
      sessionStorage.removeItem('__scroll:/');
      history.replaceState(null,'',location.pathname);
      var attempts=0;
      function tryHash(){
        var rect=hashEl.getBoundingClientRect();
        var targetY=window.scrollY+rect.top-60;
        if(document.documentElement.scrollHeight>=targetY+window.innerHeight||attempts>10){
          window.scrollTo(0,targetY);
          return;
        }
        attempts++;
        requestAnimationFrame(tryHash);
      }
      requestAnimationFrame(tryHash);
    } else {
      var saved=sessionStorage.getItem('__scroll:/');
      if(saved){
        var pos=parseInt(saved,10);
        sessionStorage.removeItem('__scroll:/');
        var attempts2=0;
        function tryRestore(){
          if(document.documentElement.scrollHeight>=pos+window.innerHeight||attempts2>10){
            window.scrollTo(0,pos);
            return;
          }
          attempts2++;
          requestAnimationFrame(tryRestore);
        }
        requestAnimationFrame(tryRestore);
      }
    }
  })();
</script>

