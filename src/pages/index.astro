        <button class="mymind-pill t-tag" data-filter="live">Live</button>
        <button class="mymind-pill t-tag" data-filter="client">Client</button>
        <button class="mymind-pill t-tag" data-filter="personal">Experiments</button>
      </div>

      <div class="puzzle-grid">
        <div class="puzzle-card" data-project="0" data-category="live">
          <div class="puzzle-img"><video src="/notes/prevue/hero.mp4" loop muted playsinline aria-label="Prevue preview"></video></div>
          <div class="puzzle-overlay"><span>Prevue</span></div>
        </div>
        <div class="puzzle-card" data-project="1" data-category="client">
          <div class="puzzle-img"><img src="/projects/studyloop.png" alt="StudyLoop App" loading="lazy"></div>
          <div class="puzzle-overlay"><span>StudyLoop App</span><span class="puzzle-subtitle">Coming soon</span></div>
        </div>
        <div class="puzzle-card" data-project="2" data-category="client">
          <div class="puzzle-img"><img src="/projects/pet-tickle.jpg" alt="Tickle" loading="lazy"></div>
          <div class="puzzle-overlay"><span>Tickle</span></div>
        </div>
        <div class="puzzle-card" data-project="3" data-category="client">
          <div class="puzzle-img"><img src="/projects/ova-app.jpg" alt="Ova App" loading="lazy"></div>
          <div class="puzzle-overlay"><span>Ova App</span></div>
        </div>
        <div class="puzzle-card" data-project="4" data-category="client">
          <div class="puzzle-img"><img src="/projects/greex-defi.jpg" alt="Greex DeFi" loading="lazy"></div>
          <div class="puzzle-overlay"><span>Greex DeFi</span></div>
        </div>
        <div class="puzzle-card" data-project="5" data-category="client">
          <div class="puzzle-img"><img src="/projects/indianoil.jpg" alt="IndianOil Dashboard" loading="lazy"></div>
          <div class="puzzle-overlay"><span>IndianOil Dashboard</span></div>
        </div>
        <div class="puzzle-card" data-project="6" data-category="client">
          <div class="puzzle-img"><img src="/projects/dealdoc-overview.jpg" alt="DealDoc" loading="lazy"></div>
          <div class="puzzle-overlay"><span>DealDoc</span></div>
        </div>
        <div class="puzzle-card" data-project="7" data-category="client">
          <div class="puzzle-img"><img src="/projects/adiagnosis.jpg" alt="ADiagnosis" loading="lazy"></div>
          <div class="puzzle-overlay"><span>ADiagnosis</span></div>
        </div>
        <div class="puzzle-card puzzle-extra" data-project="8" data-category="personal">
          <div class="puzzle-img"><img src="/projects/vault-defi.jpg" alt="Vault DeFi" loading="lazy"></div>
          <div class="puzzle-overlay"><span>Vault DeFi</span></div>
        </div>
        <div class="puzzle-card puzzle-extra" data-project="9" data-category="personal">
          <div class="puzzle-img"><img src="/projects/cycling-app.jpg" alt="Strava concept redesign" loading="lazy"></div>
          <div class="puzzle-overlay"><span>Strava concept redesign</span></div>
        </div>
        <div class="puzzle-card puzzle-extra" data-project="10" data-category="personal">
          <div class="puzzle-img"><img src="/projects/chain-landing.jpg" alt="Chain Landing" loading="lazy"></div>
          <div class="puzzle-overlay"><span>Chain Landing</span></div>
        </div>
        <div class="puzzle-card puzzle-extra" data-project="11" data-category="personal">
          <div class="puzzle-img"><img src="/projects/skeu-buttons.jpg" alt="Skeuomorphic Buttons" loading="lazy"></div>
          <div class="puzzle-overlay"><span>Skeuomorphic Buttons</span></div>
        </div>
        <div class="puzzle-card puzzle-extra" data-project="12" data-category="client">
          <div class="puzzle-img"><img src="/projects/cognix/cognix-landing.png" alt="Cognix Health" loading="lazy"></div>
          <div class="puzzle-overlay"><span>Cognix Health</span></div>
        </div>
        <div class="puzzle-card puzzle-extra" data-project="13" data-category="personal">
          <div class="puzzle-img"><img src="/projects/vercel-dashboard.jpg" alt="Vercel Dashboard" loading="lazy"></div>
          <div class="puzzle-overlay"><span>Vercel Dashboard</span></div>
        </div>
        <div class="puzzle-card puzzle-extra" data-project="14" data-category="personal">
          <div class="puzzle-img"><video src="/projects/magicpath-3.mp4" loop muted playsinline preload="none" aria-label="MagicPath animation preview"></video></div>
          <div class="puzzle-overlay"><span>MagicPath</span></div>
        </div>
        <div class="puzzle-card puzzle-extra" data-project="15" data-category="personal">
          <div class="puzzle-img"><video src="/projects/card-tilt.mp4" loop muted playsinline preload="none" aria-label="Card Tilt animation preview"></video></div>
          <div class="puzzle-overlay"><span>Card Tilt</span></div>
        </div>
        <div class="puzzle-card puzzle-extra" data-project="16" data-category="personal">
          <div class="puzzle-img"><video src="/projects/magicpath-2.mp4" loop muted playsinline preload="none" aria-label="MagicPath Experiments animation preview"></video></div>
          <div class="puzzle-overlay"><span>MagicPath Experiments</span></div>
        </div>
      </div>
      <button class="puzzle-show-more t-tag" id="puzzleShowMore" aria-expanded="false">Show more work</button>
    </div>

    <!-- ═══ NOTES — Links to individual note pages ═══ -->
    <div class="browse-section" id="sec-notes">
      <h2 class="t-display">Notes</h2>
      <p class="subtitle t-subtitle">Notes on design, code, and everything in between.</p>

      <div class="note-filters" id="noteFilters">
        <button class="mymind-pill t-tag active" data-filter="all">All</button>
        <button class="mymind-pill t-tag" data-filter="breakdowns">Breakdowns</button>
        <button class="mymind-pill t-tag" data-filter="thoughts">Thoughts</button>
        <button class="mymind-pill t-tag" data-filter="tools">Tools</button>
        <button class="mymind-pill t-tag" data-filter="learning">Learning</button>
      </div>

      <div class="note-cards" id="noteCards">
        {NOTES.map((note, i) => (
          <a href={`/notes/${note.slug}`} class={`note-card${i >= 3 ? ' note-extra' : ''}`} data-tags={note.tags.join(',')}>
            <div class="note-card-date t-tag">{note.date}{note.readTime && <span class="note-card-read-time">{note.readTime}</span>}</div>
            <div class="note-card-title t-heading-sm">{note.title}</div>
            <div class="note-card-preview t-body-sm">{note.preview}</div>
            <div class="note-card-tags">
              {note.tags.map(tag => (
                <span class="note-card-tag t-tag">{tag}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
      <button class="puzzle-show-more t-tag" id="noteShowMore" aria-expanded="false">Show more notes</button>
    </div>

    <!-- ═══ BOOKMARKS — Mymind masonry grid (no container) ═══ -->
    <div class="browse-section" id="sec-bookmarks">
      <h2 class="t-display">Saves</h2>
      <p class="subtitle t-subtitle">My bookmarks live in <a href="https://mymind.com" target="_blank" style="color:var(--accent);text-decoration:none;border-bottom:1px solid rgba(139,126,200,0.3);">Mymind</a>. Here's what's caught my eye lately.</p>

      <div class="mymind-header">
        <input type="text" class="mymind-search t-heading" id="mmindSearchInput" placeholder="Search my mind..." autocomplete="off" aria-label="Search bookmarks">
      </div>
      <div class="mymind-filters" id="mmindFilters">
        <button class="mymind-pill t-tag active" data-filter="all">All</button>
        <button class="mymind-pill t-tag" data-filter="animation">Animation</button>
        <button class="mymind-pill t-tag" data-filter="ui design">UI Design</button>
        <button class="mymind-pill t-tag" data-filter="tools">Tools</button>
        <button class="mymind-pill t-tag" data-filter="inspiration">Inspiration</button>
        <button class="mymind-pill t-tag" data-filter="notes">Notes</button>
      </div>
      <div class="mymind-grid" id="mmindGrid"></div>
      <button class="puzzle-show-more t-tag" id="mmindShowMore" aria-expanded="false">Show more bookmarks</button>
      <div class="mm-popover-wrap" id="mmindPopWrap" style="position:fixed;" role="dialog" aria-label="Bookmark details">
        <div class="sheet-handle"></div>
        <div class="mm-popover" id="mmindPopover"></div>
      </div>
      <div class="mm-scrim" id="mmindScrim"></div>
    </div>

    <!-- ═══ BOOKS — Cover grid + popover highlights ═══ -->
    <div class="browse-section" id="sec-books">
      <h2 class="t-display">Books</h2>
      <p class="subtitle t-subtitle">What I'm reading and what stuck with me</p>

      <div class="book-filters" id="bookFilters">
        <button class="mymind-pill t-tag active" data-filter="all">All</button>
        <button class="mymind-pill t-tag" data-filter="excellent">Excellent</button>
        <button class="mymind-pill t-tag" data-filter="great">Great</button>
        <button class="mymind-pill t-tag" data-filter="reading">Reading</button>
      </div>
      <div class="books-shelf" id="booksGrid"></div>
      <button class="puzzle-show-more t-tag" id="booksShowMore" aria-expanded="false">Show more books</button>
      <div class="book-pop-wrap" id="bookPopWrap" style="position:fixed;" role="dialog" aria-label="Book details">
        <div class="sheet-handle"></div>
        <div class="book-pop" id="bookPopover"></div>
      </div>
      <div class="mm-scrim" id="bookScrim"></div>
    </div>

    <!-- ═══ MEDIA — Cover grid with slide-out play button ═══ -->
    <div class="browse-section" id="sec-media">
      <h2 class="t-display">Media</h2>
      <p class="subtitle t-subtitle">Feeding my mind with</p>

      <div class="podcast-grid" id="podcastGrid"></div>
      <button class="puzzle-show-more t-tag" id="podcastShowMore" aria-expanded="false">Show more media</button>
    </div>

    <footer class="site-footer t-tag">
      <span>&copy; Raksha T 2026. V2.3.0</span>
      <span class="footer-sep">&middot;</span>
      <a href="/changelog" class="footer-link">Changelog</a>
    </footer>

  </div>
</main>

<!-- ═══ SIDE NAV (desktop: vertical lines, left edge) ═══ -->
<nav class="side-nav" id="sideNav" aria-label="Section navigation">
  <button class="side-nav-line active" data-section="sec-about" aria-label="About"><span class="side-nav-label">About</span></button>
  <button class="side-nav-line" data-section="sec-work" aria-label="Work"><span class="side-nav-label">Work</span></button>
  <button class="side-nav-line" data-section="sec-notes" aria-label="Notes"><span class="side-nav-label">Notes</span></button>
  <button class="side-nav-line" data-section="sec-bookmarks" aria-label="Saves"><span class="side-nav-label">Saves</span></button>
  <button class="side-nav-line" data-section="sec-books" aria-label="Books"><span class="side-nav-label">Books</span></button>
  <button class="side-nav-line" data-section="sec-media" aria-label="Media"><span class="side-nav-label">Media</span></button>
</nav>

