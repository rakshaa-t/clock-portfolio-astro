<button class="burger-btn" id="burgerBtn" aria-label="Open navigation menu" aria-expanded="false">
  <span class="burger-line"></span>
  <span class="burger-line"></span>
  <span class="burger-line"></span>
</button>
<div class="mobile-menu-wrap" id="mobileMenuWrap">
  <div class="sheet-handle"></div>
  <div class="mobile-menu">
    <button class="mobile-menu-item t-heading-sm active" data-section="sec-about">About</button>
    <button class="mobile-menu-item t-heading-sm" data-section="sec-work">Work</button>
    <button class="mobile-menu-item t-heading-sm" data-section="sec-notes">Notes</button>
    <button class="mobile-menu-item t-heading-sm" data-section="sec-bookmarks">Saves</button>
    <button class="mobile-menu-item t-heading-sm" data-section="sec-books">Books</button>
    <button class="mobile-menu-item t-heading-sm" data-section="sec-media">Media</button>
  </div>
</div>

